def Gulsenem(sayi): 
    if sayi==1: 
        return 1 
    else: 
        return sayi*Gulsenem(sayi-1) 
b=Gulsenem(5) 
print(b) 
 
def sanepes(n): 
    if n == 1 or n==0: 
        return 1 
    else: 
        return sanepes(n-1) + sanepes(n-2) 
 
s = sanepes(10) 
print(s) 
 
 
